node_modules/

# No ignorar /api/ en la raíz: Vercel no empaqueta carpetas .gitignore; installCommand copia
# frontend/api → api/ y sin eso /api/* devuelve 404. No subas api/ manualmente al repo.

# Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Dotenv file (no subir secretos ni DATABASE_URL reales)
.env
.env.*
!.env.example

# Cursor / IDE local
.cursor/

# API deportiva mock (resultados publicados)
frontend/server/data/sports-results.json
