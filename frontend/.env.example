# Dirección del contrato PorraFactory desplegada (obligatoria para crear/listar porras)
VITE_FACTORY_ADDRESS=0x...

# MockOracle desplegado (obligatoria para API deportiva + fulfill)
VITE_ORACLE_ADDRESS=0x...

# Producción (Vercel): mismo origen → deja VITE_ORACLE_API_URL vacío (usa /api/*).
# Solo necesitas URL externa si el front y la API están en dominios distintos.
# VITE_ORACLE_API_URL=

# Variables de servidor (Vercel: Project Settings → Environment Variables; local: .env)
# Clave del owner del MockOracle (en Anvil suele ser la cuenta 0 del deploy)
ORACLE_RPC_URL=http://127.0.0.1:8545
# Sepolia en Railway: tu RPC + ORACLE_CHAIN_ID=11155111
# ORACLE_CHAIN_ID=11155111
ORACLE_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
ORACLE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Puerto del proceso server/oracle-api.mjs (opcional)
# ORACLE_API_PORT=8787

# API deportiva (oracle-api): DATABASE_URL obligatorio (partidos + resultados en PostgreSQL).
# En frontend/: docker compose up -d
# Puerto 5433 = docker compose en frontend/ (mapeo host). Si usas Postgres local en 5432, cámbialo.
DATABASE_URL=postgresql://apuestas:apuestas@127.0.0.1:5433/apuestas

# En local con Anvil: usar red local
# VITE_USE_LOCAL_CHAIN=true
